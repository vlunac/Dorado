# ─────────────────────────────────────────────────────────────────────────────
# StartMatch — Environment Variables
# Copy this file to .env and fill in every value before running the server.
# NEVER commit .env to git.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────────────────
# SQLite (fine for hackathon, data lives in startmatch.db next to this file)
DATABASE_URL=sqlite:///./startmatch.db

# PostgreSQL (uncomment + fill in for production)
# DATABASE_URL=postgresql://USERNAME:PASSWORD@localhost:5432/startmatch

# ── JWT Secret ────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
SECRET_KEY=REPLACE_WITH_OPENSSL_OUTPUT

# ── Anthropic API (AI Summaries) ──────────────────────────────────────────────
# 1. Go to https://console.anthropic.com
# 2. Sign up / log in → API Keys → Create Key
# 3. Paste the key below (starts with sk-ant-...)
ANTHROPIC_API_KEY=sk-ant-REPLACE_ME

# ── Calendly API (Meeting Scheduling) ────────────────────────────────────────
# 1. Log in to Calendly → https://calendly.com/integrations/api_webhooks
# 2. Click "Personal Access Tokens" → Generate New Token
# 3. Paste the token below
# 4. To get your USER URI run:
#    curl -H "Authorization: Bearer YOUR_TOKEN" https://api.calendly.com/users/me
#    Copy the "uri" field from the response
CALENDLY_API_KEY=REPLACE_ME
CALENDLY_USER_URI=https://api.calendly.com/users/REPLACE_ME
